{
  "name": "ai-adapter",
  "version": "0.0.1",
  "description": "RummiArena AI Adapter Service - Multi-LLM strategy adapter for Rummikub game",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "node node_modules/typescript/bin/tsc --project tsconfig.build.json",
    "format": "node node_modules/prettier/bin/prettier.cjs --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "node node_modules/@nestjs/cli/bin/nest.js start",
    "start:dev": "node node_modules/@nestjs/cli/bin/nest.js start --watch",
    "start:debug": "node node_modules/@nestjs/cli/bin/nest.js start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "node node_modules/eslint/bin/eslint.js \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "node node_modules/jest/bin/jest.js",
    "test:watch": "node node_modules/jest/bin/jest.js --watch",
    "test:cov": "node node_modules/jest/bin/jest.js --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-jest/register node_modules/jest/bin/jest.js --runInBand",
    "test:e2e": "node node_modules/jest/bin/jest.js --config ./test/jest-e2e.json"
  },
  "overrides": {
    "multer": "2.1.1",
    "lodash": "4.18.0"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/throttler": "^6.5.0",
    "axios": "^1.6.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "ioredis": "^5.10.1",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.2",
    "@types/node": "^20.3.1",
    "@types/supertest": "^6.0.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "source-map-support": "^0.5.21",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s",
      "!**/*.spec.ts",
      "!**/node_modules/**",
      "!**/coverage/**",
      "!**/dist/**",
      "!main.ts"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
