# Game Server URL (Next.js rewrites proxy 대상, 클라이언트 브라우저에서 접근)
NEXT_PUBLIC_API_URL=http://localhost:8080

# WebSocket URL (클라이언트에서 직접 연결)
NEXT_PUBLIC_WS_URL=ws://localhost:8080

# Game Server 내부 URL (next-auth SSR → game-server 직접 호출용, K8s 내부 서비스명 사용)
GAME_SERVER_INTERNAL_URL=http://localhost:8080

# next-auth 설정
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-here

# Google OAuth 2.0 (Google Cloud Console에서 발급)
# Authorized redirect URIs: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
