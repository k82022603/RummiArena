# .env.cicd.example
# docker-compose.cicd.yml 환경 변수 예시
# 실제 사용 전: cp .env.cicd.example .env.cicd

# SonarQube DB 비밀번호 (PostgreSQL sonar 계정)
CI_SONAR_DB_PASSWORD=sonarpass

# GitLab Runner 등록 토큰
# GitLab.com → 프로젝트 → Settings → CI/CD → Runners → New project runner 에서 발급
# 형식: glrt-xxxxxxxxxxxxxxxxxxxx
RUNNER_TOKEN=
