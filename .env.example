# =============================================================================
# RummiArena - 환경 변수 템플릿
# =============================================================================
# 이 파일을 .env로 복사한 후 실제 값을 입력하세요.
#   cp .env.example .env
#
# [주의] .env 파일은 절대 Git에 커밋하지 마세요.
# =============================================================================

# --- PostgreSQL ---
POSTGRES_USER=rummikub
POSTGRES_PASSWORD=          # 로컬 개발용 비밀번호 입력 (예: REDACTED_DB_PASSWORD)
POSTGRES_DB=rummikub
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Game-server GORM DSN용 별칭 (docker-compose.dev.yml은 DB_ 접두사 사용)
DB_HOST=localhost
DB_PORT=5432
DB_USER=rummikub
DB_PASSWORD=                # POSTGRES_PASSWORD와 동일 값
DB_NAME=rummikub

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=             # 비어두면 인증 없이 접속 (로컬 dev)

# --- JWT ---
JWT_SECRET=                 # 최소 32자 랜덤 문자열 (예: openssl rand -hex 32)

# --- Google OAuth 2.0 (Frontend/NextAuth) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- NextAuth ---
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=            # 최소 32자 랜덤 문자열

# --- Admin NextAuth ---
ADMIN_NEXTAUTH_URL=http://localhost:3001

# --- AI API Keys (ai-adapter/.env 에도 동일하게 설정) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
